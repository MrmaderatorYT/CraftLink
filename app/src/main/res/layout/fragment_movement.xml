<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/oneui_background">

    <LinearLayout
        android:id="@+id/movement_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_movement"
            android:textColor="@color/oneui_text_primary"
            android:textSize="@dimen/text_size_headline"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.CraftLink.CardView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/spacing_md"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <!-- Minimap (serves as the touch surface for swiping) -->
                <com.ccs.craftlink.view.MinimapView
                    android:id="@+id/minimapView"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <TextView
                    android:id="@+id/tvCoordinates"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    android:text="X=0.0 Y=0.0 Z=0.0"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="@dimen/text_size_body"
                    android:textStyle="bold" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:padding="@dimen/spacing_sm">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnForward"
                        style="@style/Widget.CraftLink.Button"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:text="W"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:cornerRadius="32dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLeft"
                        style="@style/Widget.CraftLink.Button"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:text="A"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:cornerRadius="32dp"
                        app:layout_constraintTop_toBottomOf="@id/btnForward"
                        app:layout_constraintEnd_toStartOf="@id/btnBackward" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBackward"
                        style="@style/Widget.CraftLink.Button"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="S"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:cornerRadius="32dp"
                        app:layout_constraintTop_toBottomOf="@id/btnForward"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRight"
                        style="@style/Widget.CraftLink.Button"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:text="D"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:cornerRadius="32dp"
                        app:layout_constraintTop_toBottomOf="@id/btnForward"
                        app:layout_constraintStart_toEndOf="@id/btnBackward" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCrouch"
                        style="@style/Widget.CraftLink.Button.Outline"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:text="SHIFT"
                        android:textSize="14sp"
                        app:cornerRadius="36dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/btnLeft"
                        app:layout_constraintHorizontal_bias="0.2" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnJump"
                        style="@style/Widget.CraftLink.Button"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:text="JUMP"
                        android:textSize="14sp"
                        app:cornerRadius="36dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@id/btnRight"
                        app:layout_constraintHorizontal_bias="0.8" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <include
        android:id="@+id/view_not_connected"
        layout="@layout/view_not_connected"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible" />

</FrameLayout>
