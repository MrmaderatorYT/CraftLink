<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/oneui_background">

    <ScrollView
        android:id="@+id/settings_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings"
            android:textColor="@color/oneui_text_primary"
            android:textSize="@dimen/text_size_headline"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.CraftLink.CardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Appearance"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rg_theme_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rb_theme_system"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Follow System"
                        android:textColor="@color/oneui_text_primary"
                        android:textSize="@dimen/text_size_body"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/rb_theme_light"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="Light Mode"
                        android:textColor="@color/oneui_text_primary"
                        android:textSize="@dimen/text_size_body" />

                    <RadioButton
                        android:id="@+id/rb_theme_dark"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="Dark Mode"
                        android:textColor="@color/oneui_text_primary"
                        android:textSize="@dimen/text_size_body" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.CraftLink.CardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/layout_profile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:background="?attr/selectableItemBackground"
                    android:padding="@dimen/spacing_sm">

                    <ImageView
                        android:layout_width="@dimen/icon_size_xl"
                        android:layout_height="@dimen/icon_size_xl"
                        android:src="@drawable/ic_profile"
                        app:tint="@color/oneui_primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_username"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Not logged in"
                            android:textColor="@color/oneui_text_primary"
                            android:textSize="@dimen/text_size_subtitle" />

                        <TextView
                            android:id="@+id/tv_nickname"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/oneui_text_secondary"
                            android:textSize="@dimen/text_size_body_small" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_login"
                    style="@style/Widget.CraftLink.Button.Outline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:text="@string/login" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_change_nickname"
                    style="@style/Widget.CraftLink.Button.Text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/change_nickname" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.CraftLink.CardView"
            android:id="@+id/card_afk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:alpha="0.5"
            app:strokeColor="#66808080"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/afk_mode"
                        android:textColor="@color/oneui_text_primary"
                        android:textSize="@dimen/text_size_subtitle"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Coming soon"
                        android:textColor="@color/oneui_text_secondary"
                        android:textSize="@dimen/text_size_body_small"
                        android:textStyle="italic"
                        android:background="@drawable/bg_card_oneui"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_afk_enabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/afk_enabled"
                    android:textColor="@color/oneui_text_primary"
                    android:checked="false"
                    android:enabled="false"
                    app:thumbTint="@color/oneui_primary"
                    app:trackTint="@color/oneui_surface_variant" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_auto_reconnect"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/afk_auto_reconnect"
                    android:textColor="@color/oneui_text_primary"
                    android:checked="false"
                    android:enabled="false"
                    app:thumbTint="@color/oneui_primary"
                    app:trackTint="@color/oneui_surface_variant" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_anti_afk_movement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/afk_movement"
                    android:textColor="@color/oneui_text_primary"
                    android:checked="false"
                    android:enabled="false"
                    app:thumbTint="@color/oneui_primary"
                    app:trackTint="@color/oneui_surface_variant" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/afk_interval"
                        android:textColor="@color/oneui_text_primary"
                        android:textSize="@dimen/text_size_body" />

                    <TextView
                        android:id="@+id/tv_reconnect_interval"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30s"
                        android:textColor="@color/oneui_primary"
                        android:textSize="@dimen/text_size_body"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_reconnect_interval"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:valueFrom="10"
                    android:valueTo="120"
                    android:stepSize="5"
                    app:thumbColor="@color/oneui_primary"
                    app:trackColorActive="@color/oneui_primary"
                    app:trackColorInactive="@color/oneui_surface_variant" />


            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.CraftLink.CardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto-Eat"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textStyle="bold" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_auto_eat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="Enable Auto-Eat"
                    android:textColor="@color/oneui_text_primary"
                    app:thumbTint="@color/oneui_primary"
                    app:trackTint="@color/oneui_surface_variant" />

                <TextView
                    android:id="@+id/tv_hunger_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="Hunger: 20/20  Health: 20/20"
                    android:textColor="@color/oneui_text_secondary"
                    android:textSize="@dimen/text_size_body_small" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Eat when hunger below:"
                        android:textColor="@color/oneui_text_primary"
                        android:textSize="@dimen/text_size_body" />

                    <TextView
                        android:id="@+id/tv_hunger_threshold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="14"
                        android:textColor="@color/oneui_primary"
                        android:textSize="@dimen/text_size_body"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_hunger_threshold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="1"
                    android:valueTo="19"
                    android:stepSize="1"
                    app:thumbColor="@color/oneui_primary"
                    app:trackColorActive="@color/oneui_primary"
                    app:trackColorInactive="@color/oneui_surface_variant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.CraftLink.CardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Power Saving"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="Control which packets to receive"
                    android:textColor="@color/oneui_text_secondary"
                    android:textSize="@dimen/text_size_body_small" />

                <RadioGroup
                    android:id="@+id/rg_power_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rb_balanced"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Balanced - All packets"
                        android:textColor="@color/oneui_text_primary"
                        android:textSize="@dimen/text_size_body"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/rb_low_power"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="Low Power - Skip health/food/player info"
                        android:textColor="@color/oneui_text_primary"
                        android:textSize="@dimen/text_size_body" />

                    <RadioButton
                        android:id="@+id/rb_ultra_saving"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="Ultra Saving - Minimal packets only"
                        android:textColor="@color/oneui_text_primary"
                        android:textSize="@dimen/text_size_body" />
                </RadioGroup>

                <TextView
                    android:id="@+id/tv_power_mode_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="Receiving: KeepAlive, Chat, Position, Inventory, Chunks"
                    android:textColor="@color/oneui_text_secondary"
                    android:textSize="@dimen/text_size_body_small" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.CraftLink.CardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/app_name"
                    android:textColor="@color/oneui_text_primary"
                    android:textSize="@dimen/text_size_body" />

                <TextView
                    android:id="@+id/tv_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/version"
                    android:textColor="@color/oneui_text_secondary"
                    android:textSize="@dimen/text_size_body_small" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_credits"
                    style="@style/Widget.CraftLink.Button.Text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/credits" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/view_not_connected_settings"
        layout="@layout/view_not_connected"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</FrameLayout>
