<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_logo_craftlink"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_logo_craftlink_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CraftLink"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.ConnectionService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <receiver
            android:name=".widget.QuickConnectWidget"
            android:exported="true"
            android:label="Quick Connect (4x2)">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.ccs.craftlink.ACTION_CONNECT" />
                <action android:name="com.ccs.craftlink.ACTION_DISCONNECT" />
                <action android:name="com.ccs.craftlink.ACTION_WIDGET_UPDATE_STATUS" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_quick_connect" />
        </receiver>

        <receiver
            android:name=".widget.QuickConnectWidget2x2"
            android:exported="true"
            android:label="Quick Connect (2x2)">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.ccs.craftlink.ACTION_CONNECT" />
                <action android:name="com.ccs.craftlink.ACTION_DISCONNECT" />
                <action android:name="com.ccs.craftlink.ACTION_WIDGET_UPDATE_STATUS" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_quick_connect_2x2" />
        </receiver>

        <receiver
            android:name=".widget.QuickConnectWidget4x1"
            android:exported="true"
            android:label="Quick Connect (4x1)">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.ccs.craftlink.ACTION_CONNECT" />
                <action android:name="com.ccs.craftlink.ACTION_DISCONNECT" />
                <action android:name="com.ccs.craftlink.ACTION_WIDGET_UPDATE_STATUS" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_quick_connect_4x1" />
        </receiver>

    </application>

</manifest>
