<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:autofit="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="90dp"
    android:layout_margin="5dp"
    android:layout_marginLeft="3dp"
    android:layout_marginRight="3dp">
    <LinearLayout
        android:id="@+id/qualcosa"
        android:background="?attr/list_selector"
        android:focusable="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/server_icon"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:layout_marginLeft="2dp"
            android:layout_marginTop="2dp"
            android:layout_marginRight="2dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginRight="5dp"
            android:layout_marginEnd="5dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <me.grantland.widget.AutofitTextView
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/primary_text_dark"
                    android:id="@+id/server_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="5dp"
                    android:text=""
                    android:maxLines="1"
                    android:layout_weight="0.8"
                    android:layout_marginEnd="5dp"
                    autofit:minTextSize="10sp"/>
                <TextView
                    android:textSize="12sp"
                    android:id="@+id/ping_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="5dp"
                    android:text="Ping -1"
                    android:maxLines="1"
                    android:layout_marginEnd="5dp"/>
                <TextView
                    android:textSize="12sp"
                    android:gravity="end"
                    android:id="@+id/server_on_player"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/0"
                    android:maxLines="1"/>
            </LinearLayout>
            <me.grantland.widget.AutofitTextView
                android:textSize="20sp"
                android:gravity="center"
                android:id="@+id/server_motd"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:maxLines="2"
                autofit:minTextSize="8sp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
