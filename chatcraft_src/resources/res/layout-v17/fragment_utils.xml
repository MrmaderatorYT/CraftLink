<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:ads="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageButton
        android:id="@+id/go_avanti"
        android:background="?android:attr/selectableItemBackground"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/arrow_up"
        android:scaleType="centerCrop"
        android:text=""
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"/>
    <ImageButton
        android:id="@+id/go_left"
        android:background="?android:attr/selectableItemBackground"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/arrow_left"
        android:scaleType="centerCrop"
        android:layout_toLeftOf="@+id/go_avanti"
        android:layout_below="@+id/go_avanti"
        android:layout_toStartOf="@+id/go_avanti"/>
    <ImageButton
        android:id="@+id/go_right"
        android:background="?android:attr/selectableItemBackground"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/arrow_right"
        android:scaleType="centerCrop"
        android:text=""
        android:layout_toRightOf="@+id/go_indietro"
        android:layout_below="@+id/go_avanti"
        android:layout_toEndOf="@+id/go_indietro"/>
    <ImageButton
        android:id="@+id/go_indietro"
        android:background="?android:attr/selectableItemBackground"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/arrow_down"
        android:scaleType="centerCrop"
        android:text=""
        android:layout_below="@+id/go_left"
        android:layout_alignLeft="@+id/go_avanti"
        android:layout_alignStart="@+id/go_avanti"/>
    <Button
        android:id="@+id/flyUP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Up"
        android:layout_toRightOf="@+id/go_right"
        android:layout_alignParentTop="true"
        android:layout_toEndOf="@+id/go_right"/>
    <Button
        android:id="@+id/flyDOWN"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Down"
        android:layout_toRightOf="@+id/go_right"
        android:layout_below="@+id/flyUP"
        android:layout_toEndOf="@+id/go_right"/>
    <TextView
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:id="@+id/coordinate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:text="X=-1 Y=-1 Z = -1"
        android:layout_below="@+id/go_indietro"
        android:layout_centerHorizontal="true"/>
    <com.google.android.gms.ads.AdView
        android:layout_gravity="bottom"
        android:id="@+id/ad_view_utils"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        ads:adSize="SMART_BANNER"
        ads:adUnitId="@string/banner_ad_unit_id"/>
    <Button
        android:id="@+id/respawnButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Respawn"
        android:layout_toLeftOf="@+id/go_left"
        android:layout_alignTop="@+id/go_left"
        android:layout_toStartOf="@+id/go_left"/>
    <TextView
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:gravity="center"
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/experimental_movement"
        android:layout_below="@+id/coordinate"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"/>
</RelativeLayout>
